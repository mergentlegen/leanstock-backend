generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MERCHANT
  STAFF
}

enum TransferStatus {
  COMPLETED
  FAILED
}

enum AuditAction {
  USER_REGISTERED
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  LOGIN
  LOGOUT
  TOKEN_REFRESH
  PRODUCT_CREATED
  LOCATION_CREATED
  INVENTORY_ADJUSTED
  INVENTORY_TRANSFERRED
  INVENTORY_RESERVED
  INVENTORY_RESERVATION_COMMITTED
  INVENTORY_RESERVATION_CANCELLED
  SALE_RECORDED
  REORDER_FORECAST_VIEWED
  DEAD_STOCK_DECAY_APPLIED
}

enum EmailTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ReservationStatus {
  RESERVED
  COMMITTED
  CANCELLED
  EXPIRED
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  locations  Location[]
  products   Product[]
  inventory  InventoryItem[]
  transfers  InventoryTransfer[]
  reservations InventoryReservation[]
  sales SalesRecord[]
  auditLogs  AuditLog[]
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         UserRole @default(MERCHANT)
  emailVerifiedAt DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  emailTokens   EmailToken[]
  auditLogs     AuditLog[]

  @@index([tenantId, role])
}

model EmailToken {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  tokenHash  String            @unique
  purpose    EmailTokenPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt, expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  code      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventory     InventoryItem[]
  transfersFrom InventoryTransfer[] @relation("TransferSource")
  transfersTo   InventoryTransfer[] @relation("TransferDestination")
  reservations InventoryReservation[]
  sales SalesRecord[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
}

model Product {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid
  sku                 String
  name                String
  supplierName        String?
  supplierCost        Decimal  @db.Decimal(12, 2)
  basePrice           Decimal  @db.Decimal(12, 2)
  currentPrice        Decimal  @db.Decimal(12, 2)
  deadStockAfterDays  Int      @default(30)
  decayPercent        Decimal  @default(10.00) @db.Decimal(5, 2)
  decayIntervalHours  Int      @default(72)
  minPricePercent     Decimal  @default(50.00) @db.Decimal(5, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventory InventoryItem[]
  transfers InventoryTransfer[]
  reservations InventoryReservation[]
  sales SalesRecord[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
}

model InventoryReservation {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @db.Uuid
  productId       String            @db.Uuid
  locationId      String            @db.Uuid
  quantity        Int
  status          ReservationStatus @default(RESERVED)
  token           String            @unique
  expiresAt       DateTime
  createdByUserId String            @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([tenantId, status, expiresAt])
  @@index([tenantId, productId, locationId, status])
}

model SalesRecord {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  productId       String   @db.Uuid
  locationId      String   @db.Uuid
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  soldAt          DateTime @default(now())
  createdByUserId String   @db.Uuid
  createdAt       DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([tenantId, productId, soldAt])
  @@index([tenantId, locationId, soldAt])
}

model InventoryItem {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  productId        String   @db.Uuid
  locationId       String   @db.Uuid
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0)
  receivedAt       DateTime @default(now())
  lastDecayAt      DateTime?
  version          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, locationId])
  @@index([tenantId, productId, quantity])
  @@index([tenantId, locationId])
}

model InventoryTransfer {
  id                    String         @id @default(uuid()) @db.Uuid
  tenantId              String         @db.Uuid
  productId             String         @db.Uuid
  sourceLocationId      String         @db.Uuid
  destinationLocationId String         @db.Uuid
  quantity              Int
  status                TransferStatus @default(COMPLETED)
  createdByUserId       String         @db.Uuid
  createdAt             DateTime       @default(now())

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  sourceLocation      Location @relation("TransferSource", fields: [sourceLocationId], references: [id], onDelete: Restrict)
  destinationLocation Location @relation("TransferDestination", fields: [destinationLocationId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([tenantId, productId, createdAt])
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String?     @db.Uuid
  actorUserId String?    @db.Uuid
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor  User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
}
